    "content": "show DATABASES;\nuse dsmp\nshow TABLES\nuse DSMP2;\nshow TABLES;\nselect * from movies\n# q1. Select all the columns for all movies\nselect * from movies\n# q2 display only movie name and year\nselect name,year from movies\n# q3. Find out all the movies released in 1980\nselect * from movies where year = 1980;\n#q4. List distinct movie genre\nselect DISTINCT genre from movies\n#q5 Find all movies with Rating R\nSELECT * from movies where rating = 'R';\n#q6 Show movies with a score greater than 8\nselect * from movies where score > 8.0\n#q7 Retrive movies produced in United states\nselect * from movies where country = \"United States\"\n#q8 sort movies by year in ascending order\nselect * from movies ORDER BY year ASC, released ASC\n#q9 Sort the movies by score in descending order\nselect * from movies order by score DESC\n#Q10 display top 10 highest rated movies\nselect * from movies order by score DESC limit 10\n#q11 Find movies with a runtime greater than 120 minutes\nselect * from movies where runtime > 120\n#Q12 show movies whose budget is greater than 10million\nselect * from movies where budget = 100000000\n#Q13 count the total number of movies\nselect COUNT(*) as total_rows from movies\n\n#Q14 find the minimum movie runtime\nselect min(runtime) from movies\n# #Q14 find the minimum movie runtime\nselect * from movies where runtime = (select min(runtime) from movies)\n#q15 find the movie with maximum budget\nselect * from movies where budget = (select max(budget) from movies)\n#Q16 calulate the average movie score\nselect avg(score) from movies\n#q17show movies where gross is NULL\nselect * from movies where gross = NULL\n#Q18 show movies where budget is not null\nselect * from movies where budget != NULL\n#q19 Filter movies released after 2000\nselect * from movies where year > 2000\nselect max(year) from movies\n#q20 show movies direct by steven spielberg\nselect * from movies where director = 'Steven Spielberg'\n#q21 Find movies starring Tom Hanks\nselect * from movies where star = 'Tom Hanks'\n#q22 list the movies warner bros\nselect * from movies where company = 'Warner Bros'\n#q23 Show movies with score between 7 and 9\nselect * from movies where score BETWEEN 7 and 9\n#q24 Find the movies relased in the year 1990s\nselect * from movies where year = 1990\n#q25 Find the movies where genre is Comedy or Drama\nselect * from movies where genre = 'Comedy' or genre = 'Drama'\n#q26 Find movies not made in united states\nselect * from movies where country != 'United States'\n#Display the movie names in uppercase\nselect UPPER(name) from movies\n#q28 Find the length of each movie name\nselect LENGTH(name) as movie_name_length,name from movies\n# q30 replace spaces in movie name with underscores\nselect REPLACE(name,\" \",'_') from movies\n#q31 count the number of movies per genre\nselect count(*),genre from movies GROUP by genre\n#q32 Find average score per genre\nselect avg(score) as average, genre from movies group by genre\n#q33 Find the total budget spent per country\nselect sum(budget) as total_budget,country from movies group by country ORDER BY total_budget DESC\n#q34 show gneres having more than 50 movies\nselect count(*) as total,genre from movies group by genre having total > 50 \n#q35 Find directors who directed more than 10 movies\nselect count(*) as total_number_of_movies,director from movies group by director having total_number_of_movies > 10 ORDER BY total_number_of_movies desc \n#q36 Find actors stars appearing in more than 15 movies\nselect count(*),star from movies group by star having count(*) > 15\n\n#q37 show companies with total highest gross\nselect sum(gross),company from movies group by company ORDER BY sum(gross) desc limit 1\n#q38 Find top 5 movies by gross reveneu\nselect name from movies ORDER BY gross desc limit 5\n\n\n#q39 find movies where gross> budget\nselect * from movies where gross>budget\n#q40 calculate profit of each movie\nselect (gross - budget) as profit,name from movies order by profit DESC\n# q41 find averge profit per genre\nselect avg(gross-budget) as avg_profit,genre from movies group by genre order by avg_profit DESC\n#Q42 show all the movies released in the same year as 'The Shining'\nselect name from movies where year = (select year from movies where name = 'The Shining')\n#q43 Find movies with score higher than the average score\nselect * from movies where score > (select avg(score) from movies)\n#Q44 use a subquery to find movies with votes abouve average\nselect * from movies where votes > (Select avg(votes) from movies)\n#Q45 Find movies with the maximum runtim per year\nselect name,year,runtime from movies m1 where runtime = (select max(runtime) from movies m2 where m1.year = m2.year)\n# Q46 find the higest grossing movie per genre\nselect name,genre,gross from movies m1 where gross = (Select max(gross) from movies m2 where m1.genre = m2.genre)\n#Q47 Rank movies based on score \nselect name,score,RANK() over (order by score DESC) from movies\n#q48 Rank movies within each genre by gross\nselect name,gross,rank() over (partition by genre order by gross desc) from movies\n#q49 Find the second highest grossing movie\nselect name,gross from movies order by gross desc limit 1 OFFSET 1 \n#q50 use case to classify movies as hit/ flop based on gross\nselect name, \nCASE\n    when gross >= 1000000 THEN \"HIT\"\n    ELSE \"FLOP\"\nEND\nfrom movies\n#q51 Categorize movies by runtime (short/medium/long)\nselect name,runtime,\nCASE\n    when runtime >150 then \"long\"\n    when runtime <=150 and runtime >= 120 then \"medium\"\n    else \"short\"\nEND as movie_status\nfrom movies\nORDER BY movie_status\n#q52 Find movies whose name starts with \"The'\nselect name from movies where name like 'The%'\n#q53 Find movies whose name contains STAR\nselect name from movies where name like '%star%'\n#q55 Find the movies released in June\nselect * from movies where released like '%June%'\n#q56 Show movies with duplicate names\nSELECT name,count(*) from movies group by name having count(*) > 1\n#q57 find movies written and directed by same person\nselect name,writer,director from movies where writer=director\n#q58 count the movies per rating\nselect rating,count(*) from movies group by rating\n#q59 find country wise average score\nselect country,avg(score) from movies group by country\n#q60 Use having to filter high grossing genres\nselect genre,sum(gross) from movies group by genre having sum(gross) > 100000 order by sum(gross) DESC\n#q61 Find directors with average score above 8\nselect director,avg(score) as avg_score from movies group by director HAVING avg_score > 8 order by avg_score DESC\n#q62 Find top 3 directors by total gross\nselect director,sum(gross) from movies group by director order by sum(gross) DESC limit 3\n#q63 use in to find movies from selected countries\nselect name from movies where country in ('United Kingdom','United States')\n\n#q64 Use not in to exclude specific genres\nselect name from movies where genre not in ('Comedy','Drama','Sci-fy')\n#q65 use exists to check if a director has nay hit movies\nselect director from movies m1 where exists (select 1 from movies m2 where m1.director = m2.director and m2.score > 8)\n#q66 find movies with votes in top 10%\nselect * from ( select *, NTILE(10) over (order by votes desc) as bucket from movies)t where bucket = 1\n#q67 Find movies released before the earliest spielberg movie\nselect * from movies where year < (select MIN(year) from movies where writer = 'Steven Spielberg')\n#q68 Find companies that produced both comedy and drama movies\nselect company from movies where genre in ('Comedy','Drama') group by company having count(distinct genre) = 2\n#q69 Find movies with the same budget\nselect name,budget from movies m1 where budget in (select budget from movies group by budget having count(*) > 1) order by budget\n#q70 Find the years with the most movie releases\nselect year,count(*) from movies group by year having count(*) = (select MAX(movie_count) from (select count(*) as movie_count from movies group by year)t);\n#q71 Show running total of gross by year\nselect year,sum(gross),sum(sum(gross)) over (order by year) as sum_gross from movies group by year\n#q72 Calculate year over year gross growth\nselect year, sum(gross), \nlag(sum(gross)) over (order by year) as prev_year_gross,\nsum(gross)-lag(sum(gross)) over (order by year) as yoy\nfrom movies group by year order by YEAR\n#q73 FInd movies with missing budget but known gross\nselect name,budget,gross from movies where budget IS NULL and gross is not null\n\n#q74 Use coalesce to handle null budget\nselect name, COALESCE(budget,0) as budget from movies\n#q75 create a view for high rated movies\ncreate view high_rated_movie as \nselect name,score\nfrom movies\nwhere score > 8\n#q76 Find top 3 movies per genre using window functions \nselect * from (select name,genre,score,row_number() over (partition by genre order by score desc) as rank_in_genre from movies)t where rank_in_genre <=3\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n",
