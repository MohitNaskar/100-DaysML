    "content": "SELECT * FROM `DSMP2`.`marks`\nuse dsmp2\n# Find all the students who have a marks higher than the avg marks of their respective branch\nselect * from marks m1 where marks > (select avg(marks) from marks m2 where m1.branch = m2.branch)\nselect avg(marks),branch from marks group by branch \n#using over function \nselect *,avg(marks) over(partition by branch) from marks\nselect *,MIN(marks) over(partition by branch) from marks order by student_id\nselect * from (select *,avg(marks) over(partition by branch) as branch_avg from marks) t where t.marks > t.branch_avg\n\n\n\n\n\n\n\n\n",
